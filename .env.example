# Copy this file to .env and fill in your values.
# .env is excluded from git — never commit credentials.

SFTP_HOST=your-server.example.com
SFTP_PORT=22
SFTP_USER=your-username
SFTP_PASS=your-password         # leave empty to use key-based auth
SFTP_KEY=~/.ssh/id_rsa          # path to private key (used when SFTP_PASS is empty)
SFTP_REMOTE=/var/www/html/3dmodel
